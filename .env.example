DEEPGRAM_API_KEY=...          # STT via EU endpoint (api.eu.deepgram.com)
ELEVENLABS_API_KEY=sk_...     # TTS only (STT moved to Deepgram)
OPENAI_API_KEY=sk-proj-...
# Dutch output voice (what plays when translating TO Dutch)
# Default: Brian (nPczCjzI2devNBz1zQrb)
ELEVENLABS_VOICE_NL=nPczCjzI2devNBz1zQrb
# Farsi output voice (what plays when translating TO Farsi)
# Default: Aria (9BWtsMINqrJLrRacOk9x)
ELEVENLABS_VOICE_FA=9BWtsMINqrJLrRacOk9x
# English output voice (what plays when translating TO English)
# Default: Josh (TxGEqnHWrfWFTfGW9XjX)
ELEVENLABS_VOICE_EN=TxGEqnHWrfWFTfGW9XjX
PORT=3000
# Shared access code shown to anyone who opens the URL (leave unset for open access)
ACCESS_CODE=
