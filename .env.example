ELEVENLABS_API_KEY=sk_...
OPENAI_API_KEY=sk-proj-...
# Dutch output voice (what plays when translating TO Dutch)
# Default: Brian (nPczCjzI2devNBz1zQrb) — swap for any multilingual voice in your account
ELEVENLABS_VOICE_NL=nPczCjzI2devNBz1zQrb
# Farsi output voice (what plays when translating TO Farsi)
# Default: Aria (9BWtsMINqrJLrRacOk9x)
ELEVENLABS_VOICE_FA=9BWtsMINqrJLrRacOk9x
PORT=3000
# Shared access code shown to anyone who opens the URL (leave unset for open access)
ACCESS_CODE=
